# Copy to deploy/production.env on the VPS. Never commit the real file.

# Domain and TLS
SITE_DOMAIN=theearnalism.com
ACME_EMAIL=admin@theearnalism.com

# Same-domain deployment is fastest and simplest:
# - leave REACT_APP_BACKEND_URL and REACT_APP_API_URL empty
# - Caddy serves /api/* from FastAPI and everything else from React
REACT_APP_BACKEND_URL=
REACT_APP_API_URL=

# MongoDB: local Docker Mongo default. Keep username/password in sync with MONGO_URL.
DB_NAME=earnalism
MONGO_INITDB_ROOT_USERNAME=earnalism_app
MONGO_INITDB_ROOT_PASSWORD=replace-with-a-long-random-mongo-password
MONGO_URL=mongodb://earnalism_app:replace-with-a-long-random-mongo-password@mongo:27017/earnalism?authSource=admin

# API security
JWT_SECRET=replace-with-at-least-32-random-characters
ADMIN_EMAIL=admin@theearnalism.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
FRONTEND_URL=https://theearnalism.com
CORS_ORIGINS=https://theearnalism.com,https://www.theearnalism.com
WEB_CONCURRENCY=2
UVICORN_KEEP_ALIVE=15
UVICORN_GRACEFUL_TIMEOUT=15
MONGODB_MAX_POOL_SIZE=25
MONGODB_MIN_POOL_SIZE=1
MONGODB_MAX_CONNECTING=2
MONGODB_SERVER_SELECTION_TIMEOUT_MS=15000
MONGODB_WAIT_QUEUE_TIMEOUT_MS=5000
MULTI_REPLICA_ENABLED=true
REDIS_URL=
REDIS_KEY_PREFIX=earnalism:prod
REDIS_CACHE_ENABLED=true
REDIS_CACHE_FAIL_FAST=true
REDIS_MAXMEMORY=16gb
REDIS_MAXMEMORY_POLICY=volatile-lfu
JUDOSCALE_URL=<your-judoscale-railway-url>
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PUBLIC_PER_MINUTE=300000
RATE_LIMIT_READER_PER_MINUTE=150000
PUBLIC_CACHE_TTL_SECONDS=300
PUBLIC_CACHE_MAX_ENTRIES=512
HOME_BOOK_LIMIT=500
HOME_BOOK_PAGE_DEFAULT_LIMIT=8
HOME_BOOK_PAGE_MAX_LIMIT=24

# Razorpay live mode
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_MODE=live

# Cloudinary image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional B2/S3 retry hardening for large audiobook uploads.
B2_S3_MAX_ATTEMPTS=5

# Optional Bengali audiobook QA/polish background job.
# Dry-run audits do not synthesize or upload. --commit requires a configured
# TTS command plus Cloudinary/B2 credentials.
BENGALI_TTS_PROVIDER=command
BENGALI_TTS_COMMAND=node scripts/audio/tts/azureBengaliTts.js --input "{input}" --output "{output}" --voice "bn-IN-TanishaaNeural"
BENGALI_TTS_SUPPORTS_SSML=true
BENGALI_TTS_VOICE_ID=bn-IN-TanishaaNeural
BENGALI_TTS_OUTPUT_FORMAT=mp3
BENGALI_TTS_CHUNK_CHARS=3600
BENGALI_TTS_COMMAND_TIMEOUT_MS=300000
BENGALI_TTS_CONCURRENCY=1
BENGALI_TTS_REQUEST_DELAY_MS=3000
BENGALI_TTS_MAX_RETRIES=8
BENGALI_TTS_RETRY_BASE_DELAY_MS=30000
BENGALI_TTS_RETRY_MAX_DELAY_MS=600000
BENGALI_TTS_RETRY_JITTER=true
BENGALI_TTS_PAUSE_ON_429=true
BENGALI_TTS_RATE=+3%
BENGALI_TTS_PITCH=+1Hz
BENGALI_TTS_PAUSE_PROFILE=natural-expressive
BENGALI_AUDIO_QA_THRESHOLD=9.3
BENGALI_AUDIO_PRONUNCIATION_LEXICON=
BENGALI_AUDIO_POLISH_STORAGE_FOLDER=earnalism/audiobooks-polished
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia
# Optional comma-separated fallback regions; set matching AZURE_SPEECH_KEY_<REGION_SUFFIX> keys.
AZURE_SPEECH_FALLBACK_REGIONS=
AZURE_BENGALI_VOICE=bn-IN-TanishaaNeural
AZURE_SPEECH_OUTPUT_FORMAT=audio-24khz-48kbitrate-mono-mp3

# Optional English audiobook QA/polish background job.
# Independent from Bengali; dry-run remains default unless --commit is passed.
# Supported providers: azure, edge, piper, command.
# Azure keeps SSML/prosody support. Edge/Piper use plaintext so Azure credits are not required.
ENGLISH_TTS_PROVIDER=edge
# Edge default command when ENGLISH_TTS_PROVIDER=edge:
# EDGE_TTS_COMMAND=edge-tts --voice en-IN-NeerjaNeural --rate=+4% --pitch=+1Hz --file "{input}" --write-media "{output}"
# Azure command if you re-enable Azure later:
# AZURE_ENGLISH_TTS_COMMAND=node scripts/audio/tts/azureEnglishTts.js --input "{input}" --output "{output}" --voice "en-IN-NeerjaNeural"
# Piper command:
# PIPER_TTS_COMMAND=scripts/audio/tts/piperEnglishTts.sh "{input}" "{output}"
# Only set ENGLISH_TTS_COMMAND when ENGLISH_TTS_PROVIDER=command.
ENGLISH_TTS_COMMAND=
ENGLISH_TTS_SUPPORTS_SSML=false
ENGLISH_TTS_VOICE_ID=en-IN-NeerjaNeural
ENGLISH_TTS_OUTPUT_FORMAT=mp3
ENGLISH_TTS_CHUNK_CHARS=3600
ENGLISH_TTS_KEEP_CHUNKS=true
ENGLISH_TTS_COMMAND_TIMEOUT_MS=300000
ENGLISH_TTS_CONCURRENCY=1
ENGLISH_TTS_REQUEST_DELAY_MS=3000
ENGLISH_TTS_MAX_RETRIES=8
ENGLISH_TTS_RETRY_BASE_DELAY_MS=30000
ENGLISH_TTS_RETRY_MAX_DELAY_MS=600000
ENGLISH_TTS_RETRY_JITTER=true
ENGLISH_TTS_PAUSE_ON_429=true
ENGLISH_TTS_RATE=+4%
ENGLISH_TTS_PITCH=+1Hz
ENGLISH_TTS_PAUSE_PROFILE=english-natural-expressive
ENGLISH_AUDIO_QA_THRESHOLD=9.3
ENGLISH_AUDIO_PRONUNCIATION_LEXICON=
ENGLISH_AUDIO_POLISH_STORAGE_FOLDER=earnalism/audiobooks-polished
AZURE_ENGLISH_VOICE=en-IN-NeerjaNeural
AZURE_ENGLISH_LOCALE=en-IN
# Optional Piper local voice model for ENGLISH_TTS_PROVIDER=piper.
PIPER_ENGLISH_MODEL=models/piper/en/en_US-lessac-medium.onnx
PIPER_TTS_COMMAND=
EDGE_TTS_COMMAND=
AZURE_ENGLISH_TTS_COMMAND=

# Optional orphaned audiobook storage cleanup. Always run dry-run first.
AUDIOBOOK_CLEANUP_PREFIXES=earnalism/audiobooks/,earnalism/audiobooks-polished/
AUDIOBOOK_CLEANUP_MIN_AGE_DAYS=2
AUDIOBOOK_CLEANUP_DELETE_LIMIT=100

# Growth OS control plane. Dry-run-only is the production-safe default.
GROWTH_OS_ENABLED=true
GROWTH_OS_DRY_RUN_ONLY=true
GROWTH_OS_PUBLIC_EXECUTION_ENABLED=false
GROWTH_OS_DAILY_BUDGET_INR=500
GROWTH_OS_MAX_ACTIONS_PER_RUN=12
GROWTH_OS_MAX_MESSAGES_PER_DAY=100
GROWTH_OS_MAX_SOCIAL_POSTS_PER_DAY=2
GROWTH_OS_MAX_LANDING_PAGES_PER_DAY=1
GROWTH_OS_MAX_CREATOR_OUTREACH_PER_DAY=10
GROWTH_OS_MAX_INSTITUTION_OUTREACH_PER_DAY=10

# Authentication
GOOGLE_CLIENT_ID=
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Optional analytics. Leave empty to disable PostHog.
REACT_APP_POSTHOG_KEY=
REACT_APP_POSTHOG_HOST=https://us.i.posthog.com
