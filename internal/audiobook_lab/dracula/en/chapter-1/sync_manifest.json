      "sentence_id": "s001",
      "chapter": 1,
      "chunk_id": "c001",
      "text": "CHAPTER I. JONATHAN HARKER’S JOURNAL",
      "start_ms": null,
      "end_ms": null,
      "timing_source": "placeholder_manual_alignment_required",
      "sync_level": "sentence",
      "sync_status": "HOLD_SYNC_QA_REQUIRED",
