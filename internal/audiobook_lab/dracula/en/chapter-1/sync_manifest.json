      "public": false
    },
    {
      "text_fragment_id": "dracula-chapter-001-s002",
      "sentence_id": "s002",
      "chapter": 1,
      "chunk_id": "c001",
      "text": "(_Kept in shorthand._)",
      "start_ms": null,
      "end_ms": null,
      "timing_source": "placeholder_manual_alignment_required",
      "sync_level": "sentence",
      "sync_status": "HOLD_SYNC_QA_REQUIRED",
      "audio_hash": "93e98fa4d2634402e394b509b0cfc78191372e3a7ab42b5e8155defedecb6fd2",
