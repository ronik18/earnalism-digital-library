      "chapter_id": "chapter-001",
      "paragraph_index": 1,
      "sentence_index": 2,
      "text": "M., on 1st May, arriving atVienna early next morning; should have arrived at 6:46, but train was anhour late.",
      "start_ms": 6600,
      "end_ms": 15000,
      "confidence": 0.72,
      "sync_level": "sentence",
      "source_hash": "f4f569c1a5486a552c3bffaaa65ecb0828a3585cccd3d702dee6dd7be00394d7",
      "audio_hash": "sha256:placeholder-no-audio-generated",
