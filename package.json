{
  "scripts": {
    "regression": "jest --config regression/jest.config.js --runInBand",
    "regression:ci": "CI=true REGRESSION_MODE=pr npm run regression -- --json --outputFile=regression/results.json",
    "regression:go-live": "CI=true REGRESSION_MODE=go-live npm run regression -- --json --outputFile=regression/results.json",
    "regression:canary": "REGRESSION_MODE=canary node regression/scripts/post-deploy-canary.js",
    "regression:visual:update": "node regression/scripts/update-visual-baselines.js",
    "regression:visual:ci": "REGRESSION_MODE=visual-ci npm run regression -- modules/02-rendering-visual.test.*",
    "regression:legacy": "bash scripts/run_regression_suite.sh",
    "regression:e2e": "node scripts/e2e_regression.mjs",
    "monitor:production": "node scripts/production_monitor.mjs",
    "catalog:audit": "node scripts/audit-public-content.mjs",
    "audio:preflight": "python3 scripts/open_source_audiobook_onboarding.py preflight",
    "audio:audit": "python3 scripts/open_source_audiobook_onboarding.py audit",
    "audio:onboard:dry": "python3 scripts/open_source_audiobook_onboarding.py generate --dry-run",
    "audiobook:missing:dry": ".venv-audio/bin/python scripts/open_source_audiobook_onboarding.py generate --manifest audio_manifests/missing_audiobooks_20260609.json --local-only --no-include-drafts --include-published --dry-run --order-shortest-first",
    "audiobook:missing:validate": ".venv-audio/bin/python scripts/open_source_audiobook_onboarding.py generate --manifest audio_manifests/missing_audiobooks_20260609.json --local-only --no-include-drafts --include-published --validate-only --order-shortest-first",
    "audiobook:missing": ".venv-audio/bin/python scripts/open_source_audiobook_onboarding.py generate --manifest audio_manifests/missing_audiobooks_20260609.json --local-only --no-include-drafts --include-published --order-shortest-first",
    "audiobook:b2:blocked": ".venv-audio/bin/python scripts/open_source_audiobook_onboarding.py generate --local-only --no-include-drafts --include-published --no-skip-live-audio-assets --upload-to-storage --sync-flags --book frankenstein --book the-picture-of-dorian-gray --book the-secret-garden --book my-life-and-work --book pride-and-prejudice --book dracula --book great-expectations",
    "audio:backfill": "bash scripts/run_audiobook_backfill.sh",
    "loadtest": "k6 run scripts/k6_10x_spike.js",
    "load:100": "k6 run scripts/k6_load_100.js",
    "load:10x": "bash scripts/run_10x_load_gate.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@aws-sdk/lib-storage": "^3.1065.0",
    "cloudinary": "^2.10.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "playwright": "^1.60.0"
  }
}
