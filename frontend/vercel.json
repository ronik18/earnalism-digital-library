      "source": "/products/:path*",
      "destination": "/api/removed-content?path=/products/:path*"
    },
    {
      "source": "/product-category/:path*",
      "destination": "/api/removed-content?path=/product-category/:path*"
    },
    {
      "source": "/shop/:path*",
      "destination": "/api/removed-content?path=/shop/:path*"
    },
    {
      "source": "/blog/:path*",
      "destination": "/api/removed-content?path=/blog/:path*"
    },
    {
      "source": "/post/:path*",
      "destination": "/api/removed-content?path=/post/:path*"
    },
    {
      "source": "/category/:path*",
      "destination": "/api/removed-content?path=/category/:path*"
    },
    {
      "source": "/tag/:path*",
