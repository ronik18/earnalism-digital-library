{
  "framework": "create-react-app",
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "ignoreCommand": "node scripts/vercel-ignore-build.mjs",
  "redirects": [
    {
      "source": "/book/moby-dick-or-the-whale",
      "destination": "/library",
      "permanent": false
    },
    {
      "source": "/book/moby-dick-or-the-whale/",
      "destination": "/library",
      "permanent": false
    },
    {
      "source": "/reader/moby-dick-or-the-whale",
      "destination": "/library",
      "permanent": false
