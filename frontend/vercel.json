    },
    {
      "source": "/my-account",
      "destination": "/api/removed-content?path=/my-account"
    },
    {
      "source": "/woocommerce",
      "destination": "/api/removed-content?path=/woocommerce"
    },
    {
      "source": "/sample-product",
      "destination": "/api/removed-content?path=/sample-product"
    },
    {
      "source": "/placeholder-product",
      "destination": "/api/removed-content?path=/placeholder-product"
    },
    {
      "source": "/lorem-ipsum",
      "destination": "/api/removed-content?path=/lorem-ipsum"
    },
    {
      "source": "/wp-admin",
      "destination": "/api/removed-content?path=/wp-admin"
